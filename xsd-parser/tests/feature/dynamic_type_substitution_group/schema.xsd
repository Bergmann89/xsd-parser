<?xml version="1.0" encoding="UTF-8"?>
<schema xmlns="http://www.w3.org/2001/XMLSchema"
    xmlns:xs="http://www.w3.org/2001/XMLSchema"
    xmlns:tns="http://example.com"
    targetNamespace="http://example.com">

    <element name="list">
        <complexType>
            <sequence>
                <element ref="tns:animal" minOccurs="0" maxOccurs="unbounded" />
            </sequence>
        </complexType>
    </element>

    <element name="animal" type="tns:animal" abstract="true" />
    <element name="cat" type="tns:cat" substitutionGroup="tns:animal" />
    <element name="dog" type="tns:dog" substitutionGroup="tns:animal" />

    <complexType name="animal">
        <attribute name="id" type="xs:int" use="required" />
    </complexType>

    <complexType name="cat">
        <complexContent>
            <extension base="tns:animal">
                <attribute name="breed" type="xs:string" use="required" />
            </extension>
        </complexContent>
    </complexType>

    <complexType name="dog" abstract="true">
        <complexContent>
            <extension base="tns:animal">
                <attribute name="name" type="xs:string" use="required" />
            </extension>
        </complexContent>
    </complexType>

    <complexType name="labrador">
        <complexContent>
            <extension base="tns:dog">
                <attribute name="color" type="xs:string" use="required" />
            </extension>
        </complexContent>
    </complexType>

    <complexType name="beagle">
        <complexContent>
            <extension base="tns:dog">
                <attribute name="age" type="xs:int" use="required" />
            </extension>
        </complexContent>
    </complexType>
</schema>
